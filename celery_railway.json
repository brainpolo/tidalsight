{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK"
    },
    "deploy": {
        "startCommand": "celery -A tidalsight worker --loglevel=info --concurrency=5 --max-tasks-per-child=50 --max-memory-per-child=400000",
        "restartPolicyType": "ON_FAILURE"
    }
}
