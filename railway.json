{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK",
        "buildCommand": "npm install && npm run build && python manage.py collectstatic --noinput"
    },
    "deploy": {
        "preDeployCommand": ["python manage.py migrate"],
        "startCommand": "gunicorn tidalsight.asgi:application --worker-class uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT --preload --workers 4 --timeout 30 --max-requests 750 --max-requests-jitter 250 --graceful-timeout 60",
        "healthcheckPath": "/",
        "healthcheckTimeout": 100,
        "restartPolicyType": "on_failure"
    }
}
