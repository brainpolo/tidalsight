{
  "name": "tidalsight",
  "private": true,
  "scripts": {
    "dev": "npx @tailwindcss/cli -i static/css/input.css -o static/css/dist.css --watch",
    "build:css": "npx @tailwindcss/cli -i static/css/input.css -o static/css/dist.css --minify",
    "build:icons": "npx esbuild static/js/src/icons.js --bundle --outfile=static/js/icons.bundle.js --minify",
    "build": "npm run build:css && npm run build:icons"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.2.1"
  },
  "dependencies": {
    "htmx.org": "^2.0.8",
    "lucide": "^0.577.0"
  }
}
